{
  "id": "kagi-search",
  "name": "Kagi Search",
  "description": "Search the web using the Kagi Search API — structured results with no AI synthesis",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "Kagi API key (overrides env var and file)"
      },
      "limit": {
        "type": "number",
        "description": "Default max results to return (1-20)",
        "default": 5
      },
      "tavilyApiKey": {
        "type": "string",
        "description": "Tavily API key (overrides TAVILY_API_KEY env var and file)"
      }
    }
  },
  "uiHints": {
    "apiKey": { "label": "Kagi API Key", "sensitive": true },
    "limit": { "label": "Default result limit", "placeholder": "5" },
    "tavilyApiKey": { "label": "Tavily API Key", "sensitive": true }
  }
}
